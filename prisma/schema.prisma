generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id                  String    @id @default(cuid())
  channelType         String    // line, slack, teams, web
  externalThreadId    String
  title               String?
  participantsSummary String?
  contextType         String    @default("unknown") // family, business_internal, business_external, client, unknown
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  messages      Message[]
  interventions Intervention[]
  summaries     ConversationSummary[]
  relationship  GroupRelationship?

  @@unique([channelType, externalThreadId])
  @@index([updatedAt])
}

model Message {
  id                String   @id @default(cuid())
  conversationId    String
  externalMessageId String?
  senderId          String
  senderRole        String   @default("human") // human, bot, system
  senderDisplayName String?
  text              String
  timestamp         DateTime
  detectedIntent    String?  // normal, rewrite_request, summarize_request, mediation_request, conflict_signal, cooldown_needed, clarification_needed
  conflictScore     Int?     // 0-100
  metadata          Json?
  createdAt         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  interventions Intervention[]

  @@unique([conversationId, externalMessageId])
  @@index([conversationId, timestamp])
}

model Intervention {
  id               String   @id @default(cuid())
  conversationId   String
  triggerMessageId String?
  triggerType      String   // manual_rewrite, manual_summary, auto_mediation, cooldown, clarification, safety_escalation
  severity         String?  // low, medium, high (for auto_mediation)
  score            Int?
  reason           String?
  responseText     String
  createdAt        DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  triggerMessage Message?     @relation(fields: [triggerMessageId], references: [id])

  @@index([conversationId, createdAt])
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model LlmUsage {
  id              String   @id @default(cuid())
  conversationId  String?
  messageId       String?
  purpose         String   // intent, conflict, mediation, rewrite, summary, chat, safety
  model           String
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  responseTimeMs  Int
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([purpose])
}

model LineUser {
  id                String    @id @default(cuid())
  lineUserId        String    @unique
  displayName       String?
  followedAt        DateTime  @default(now())
  trialEndsAt       DateTime
  trialReminderSent Boolean   @default(false)
  unfollowedAt      DateTime?
  lastActiveAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  dmSubscription    DmSubscription?

  @@index([trialEndsAt])
}

model DmSubscription {
  id                    String   @id @default(cuid())
  lineUserId            String   @unique
  status                String   @default("active") // active, past_due, canceled, expired
  stripeSubscriptionId  String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user LineUser @relation(fields: [lineUserId], references: [lineUserId])

  @@index([status])
}

model GroupSubscription {
  id                    String   @id @default(cuid())
  groupId               String   @unique
  payerLineUserId       String
  status                String   @default("active") // active, past_due, canceled, expired
  stripeSubscriptionId  String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([groupId])
  @@index([payerLineUserId])
  @@index([status])
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique  // lineUserId or slackUserId:teamId
  channelType     String             // line, slack
  displayName     String?
  personality     String?            // 性格傾向メモ
  topics          String?            // よく相談するテーマ
  preferences     String?            // 対応上の注意点
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([channelType])
}

model GroupRelationship {
  id              String   @id @default(cuid())
  conversationId  String   @unique
  members         Json?              // メンバー情報 { "Aさん": { role, sensitivity } }
  relationships   Json?              // 関係性 [{ pair, status, pastConflicts, effectiveMediation }]
  groupNorms      String?            // グループの空気感メモ
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
}

model ConversationSummary {
  id                String   @id @default(cuid())
  conversationId    String
  summary           String
  messagesCount     Int      // how many messages this summary covers
  messageRangeEnd   DateTime // timestamp of last message included
  version           Int      @default(1)
  createdAt         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, version])
}

model GroupMembership {
  id             String   @id @default(cuid())
  lineUserId     String
  groupId        String
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())

  @@unique([lineUserId, groupId])
  @@index([lineUserId])
  @@index([groupId])
}

model SlackWorkspace {
  id                String   @id @default(cuid())
  teamId            String   @unique
  teamName          String
  botToken          String
  botUserId         String?
  installedByUserId String?
  installedByName   String?
  signingSecret     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users SlackUser[]

  @@index([teamId])
}

model SlackUser {
  id              String    @id @default(cuid())
  slackUserId     String
  teamId          String
  displayName     String?
  trialEndsAt     DateTime
  trialReminderSent Boolean @default(false)
  lastActiveAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  dmSubscription SlackDmSubscription?
  workspace      SlackWorkspace @relation(fields: [teamId], references: [teamId])

  @@unique([slackUserId, teamId])
  @@index([teamId])
  @@index([trialEndsAt])
}

model SlackDmSubscription {
  id                    String   @id @default(cuid())
  slackUserId           String
  teamId                String
  status                String   @default("active") // active, past_due, canceled, expired
  stripeSubscriptionId  String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user SlackUser @relation(fields: [slackUserId, teamId], references: [slackUserId, teamId])

  @@unique([slackUserId, teamId])
  @@index([status])
}

model DailyMetric {
  id                      String   @id @default(cuid())
  date                    DateTime @unique @db.Date

  // LINE
  lineNewUsers            Int      @default(0)
  lineUnfollows           Int      @default(0)
  lineTrialUsers          Int      @default(0)
  lineActiveDmSubs        Int      @default(0)
  lineActiveGroupSubs     Int      @default(0)
  lineCanceledDmSubs      Int      @default(0)  // その日に解約されたDM数
  lineCanceledGroupSubs   Int      @default(0)  // その日に解約されたグループ数
  lineDau                 Int      @default(0)

  // Slack
  slackNewUsers           Int      @default(0)
  slackWorkspaces         Int      @default(0)
  slackTrialUsers         Int      @default(0)
  slackActiveDmSubs       Int      @default(0)
  slackActiveChannelSubs  Int      @default(0)
  slackCanceledDmSubs     Int      @default(0)
  slackCanceledChannelSubs Int     @default(0)
  slackDau                Int      @default(0)

  // 全体
  totalMessages           Int      @default(0)  // その日のメッセージ数
  totalInterventions      Int      @default(0)  // その日の介入数
  mrrJpy                  Int      @default(0)  // MRR（円）
  apiCostJpy              Int      @default(0)  // APIコスト（円）

  createdAt               DateTime @default(now())

  @@index([date])
}

model SlackChannelSubscription {
  id                    String   @id @default(cuid())
  channelId             String   @unique
  teamId                String
  payerSlackUserId      String
  status                String   @default("active") // active, past_due, canceled, expired
  stripeSubscriptionId  String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([channelId])
  @@index([payerSlackUserId])
  @@index([status])
}
